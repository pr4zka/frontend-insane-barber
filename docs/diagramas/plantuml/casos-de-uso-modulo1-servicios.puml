actor "Recepcionista" as Recep
actor "Barbero" as Barbero

rectangle "Módulo 1 — Gestión de Servicios" {
    usecase "Registrar servicio" as UC1
    usecase "Editar servicio" as UC2
    usecase "Registrar categoría" as UC3
    usecase "Definir precio" as UC4
    usecase "Definir duración" as UC5
    usecase "Registrar promoción" as UC6
    usecase "Registrar descuento" as UC7
