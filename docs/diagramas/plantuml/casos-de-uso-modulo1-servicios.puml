    usecase "Crear orden de servicio" as UC10
    usecase "Registrar presupuesto" as UC11
    usecase "Imprimir presupuesto" as UC12
    usecase "Registrar insumo" as UC13
    usecase "Registrar insumos utilizados" as UC14
    usecase "Ver informes de servicios" as UC15
}

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC4
Admin -- UC5
Admin -- UC6
Admin -- UC7
Admin -- UC13
Admin -- UC15

Recep -- UC8
Recep -- UC9
