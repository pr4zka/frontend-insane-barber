@startuml Casos de Uso - Módulo 3: Caja y Ventas

left to right direction
skinparam packageStyle rectangle

actor "Administrador" as Admin
actor "Recepcionista" as Recep

rectangle "Módulo 3 — Caja y Ventas" {
    usecase "Abrir caja" as UC1
    usecase "Cerrar caja" as UC2
    usecase "Realizar arqueo" as UC3
    usecase "Registrar cobro efectivo" as UC4
    usecase "Registrar cobro Dpago" as UC5
    usecase "Seleccionar método de pago" as UC6
    usecase "Registrar movimiento de caja" as UC7
    usecase "Generar comprobante de pago" as UC8
    usecase "Consultar libro de ventas" as UC9
    usecase "Emitir nota de crédito" as UC10
    usecase "Emitir nota de débito" as UC11
    usecase "Generar recaudaciones a depositar" as UC12
    usecase "Gestionar cuentas a cobrar" as UC13
    usecase "Ver reporte diario" as UC14
    usecase "Ver reporte mensual" as UC15
    usecase "Ver informes de caja" as UC16
}

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC9
Admin -- UC10
Admin -- UC11
Admin -- UC12
Admin -- UC13
Admin -- UC14
Admin -- UC15
Admin -- UC16

Recep -- UC1
Recep -- UC2
Recep -- UC4
Recep -- UC5
Recep -- UC6
Recep -- UC7
Recep -- UC8
Recep -- UC14

@enduml
